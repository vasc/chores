{
  "name": "chores-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "migrate": "bun run src/db/migrate.ts up",
    "migrate:down": "bun run src/db/migrate.ts down",
    "schema": "bun run src/schema/print.ts",
    "sync": "bun run schema && cp schema.graphql ../app/lib/graphql/schema.graphql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pothos/core": "^4.3.0",
    "@pothos/plugin-scope-auth": "^4.1.0",
    "bcryptjs": "^2.4.3",
    "graphql": "^16.9.0",
    "graphql-scalars": "^1.23.0",
    "graphql-yoga": "^5.7.0",
    "jose": "^5.9.0",
    "kysely": "^0.27.4",
    "pg": "^8.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/bun": "^1.1.10",
    "@types/pg": "^8.11.10",
    "typescript": "^5.6.2"
  }
}
